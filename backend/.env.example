# MongoDB Connection String
# Get this from MongoDB Atlas cluster (e.g., mongodb+srv://<user>:<password>@cluster0.mongodb.net/?)
MONGODB_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Groq API Key for Llama-3 Inference
# Get this from https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
