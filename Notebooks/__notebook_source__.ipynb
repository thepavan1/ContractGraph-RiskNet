kg_data = ml_data.copy()


# Schedule pressure:
# long projects are affected more by delay clauses

kg_data["schedule_contract_risk"] = (

    kg_data["duration_years"]

    *

    schedule_importance

)



# Financial pressure:
# expensive projects are affected more by financial clauses

kg_data["financial_contract_risk"] = (

    kg_data["log_project_cost"]

    *

    financial_importance

)



# Quality risk:
# environment complexity proxy

kg_data["quality_contract_risk"] = (

    kg_data["environment_risk"]

    *

    quality_importance

)



# Termination exposure

kg_data["termination_contract_risk"] = (

    kg_data["funding_gap_ratio"]

    *

    termination_importance

)



kg_data.head()





kg_data.to_csv(
    "ContractGraph_RiskNet_FinalDataset.csv",
    index=False
)


